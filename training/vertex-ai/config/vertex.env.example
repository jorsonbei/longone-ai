VERTEX_PROJECT_ID=your-google-cloud-project-id
VERTEX_REGION=us-central1
VERTEX_GCS_BUCKET=your-gcs-bucket-name
VERTEX_GCS_PREFIX=wuxing-training

VERTEX_SFT_BASE_MODEL=gemini-2.5-flash
VERTEX_PREFERENCE_BASE_MODEL=gemini-2.5-flash
VERTEX_TUNED_MODEL_PREFIX=wuxing-os
# Fill this after a tuning job succeeds, for local Express runtime.
VERTEX_TUNED_MODEL=

VERTEX_SFT_EPOCHS=3
VERTEX_SFT_LR_MULTIPLIER=1
VERTEX_SFT_ADAPTER_SIZE=ADAPTER_SIZE_FOUR

VERTEX_PREFERENCE_EPOCHS=1
VERTEX_PREFERENCE_LR_MULTIPLIER=1
VERTEX_PREFERENCE_ADAPTER_SIZE=ADAPTER_SIZE_FOUR
VERTEX_PREFERENCE_BETA=0.1

# Optional.
VERTEX_SERVICE_ACCOUNT=
VERTEX_KMS_KEY_NAME=
