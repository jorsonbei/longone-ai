{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "npm run build:wuxing-corpus",
    "dev": "vite --port=3000 --host=0.0.0.0",
    "prestart": "npm run build:wuxing-corpus",
