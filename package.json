    "build": "vite build",
    "preview": "vite preview",
    "precf:dev": "npm run build:wuxing-corpus",
    "cf:dev": "wrangler dev",
    "precf:deploy": "npm run build:wuxing-corpus",
    "cf:deploy": "wrangler deploy",
    "clean": "rm -rf dist",
    "build:wuxing-corpus": "tsx scripts/build-wuxing-corpus.ts",
    "vertex:prepare-training": "tsx scripts/prepare-vertex-training.ts",
