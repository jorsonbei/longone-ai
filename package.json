    "vertex:render-requests": "tsx scripts/render-vertex-tuning-requests.ts",
    "vertex:stage": "bash scripts/stage-vertex-datasets.sh",
    "vertex:submit:sft": "bash scripts/submit-vertex-tuning.sh sft",
    "vertex:submit:preference": "bash scripts/submit-vertex-tuning.sh preference",
    "vertex:poll": "tsx scripts/poll-vertex-tuning.ts",
    "prelint": "npm run build:wuxing-corpus",
    "lint": "tsc --noEmit",
    "preself-test": "npm run build:wuxing-corpus",
    "self-test": "tsx scripts/self-test.ts"
  },
  "dependencies": {
